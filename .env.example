# VisionCraft Environment Configuration
# Copy this to .env

SECRET_KEY=django-insecure-visioncraft-dev-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Use SQLite (easy local dev - no PostgreSQL needed)
USE_SQLITE=True

# PostgreSQL (only needed if USE_SQLITE=False)
DB_NAME=visioncraft_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432
